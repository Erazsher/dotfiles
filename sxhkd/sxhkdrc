# make sxhkd reload its configuration files:
super + Escape
	pkill -USR1 -x sxhkd -c ~/.config/sxhkd/sxhkdrc ;\
	herbe "sxhkd has been restarted"

# script 1 bluetooth
super + shift + b
	~/.scripts/bluetooth.sh

# script 2 wifi
super + shift + w
	~/.scripts/wifi.sh

# script 3 screenshot
ctrl + alt + @x    	
         maimit

# script 4 system-
alt + shift + q
	dash /usr/local/bin/systemact
# terminal
super + Return
	$TERMINAL

# browser
super + w
	firefox








