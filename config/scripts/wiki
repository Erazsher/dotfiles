#░░████╔═████║░██║██╔═██╗░██║██╔═══╝░██╔══╝░░██║░░██║██║██╔══██║
#░░╚██╔╝░╚██╔╝░██║██║░╚██╗██║██║░░░░░███████╗██████╔╝██║██║░░██║
#░░░╚═╝░░░╚═╝░░╚═╝╚═╝░░╚═╝╚═╝╚═╝░░░░░╚══════╝╚═════╝░╚═╝╚═╝░░╚═╝

name=$1
case=$2
cd /tmp/ &&  curl -LO https://en.wikipedia.org/api/rest_v1/page/pdf/$name  
zathura /tmp/$name

case $case in
   -s)
      mv /tmp/$name /home/sanal/documents/wikipedia/$name
      ;;
   *)
      rm /tmp/$name 
     ;;
esac






















